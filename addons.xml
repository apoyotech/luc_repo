<addon id="plugin.video.luc_kodi" name="[B][COLOR ff00fa9a]luc_[/COLOR]kodi[/B]" provider-name="[COLOR fffdb515]apoyotech[/COLOR]" version="1.0.47">
	<requires>
		<import addon="xbmc.python" version="3.0.1" />
		<import addon="script.module.requests" />
		<import addon="script.module.beautifulsoup4" />
		<import addon="plugin.video.youtube" optional="true" />
	</requires>
	<extension point="xbmc.python.pluginsource" library="luc_kodi.py">
		<provides>video</provides>
	</extension>
	<extension point="xbmc.service" library="service.py" />
	<extension point="xbmc.python.module" library="resources/lib/" />
	<extension point="xbmc.addon.metadata">
		<reuselanguageinvoker>true</reuselanguageinvoker>
		<summary lang="en">Front-end for third-party torrent indexers and debrid services that you configure with your own accounts. Hosts no content and provides no links.</summary>
		<description lang="en">[COLOR ffa9d3c5]luc_kodi is a front-end (user interface) for third-party services that you configure with your own accounts: debrid services such as Real-Debrid, AllDebrid, Premiumize or TorBox, and torrent indexers. The add-on does not host, store, upload or distribute any media, and it does not embed or include any links to content. Every source is located and resolved at run time by the third-party services you have configured with your own credentials. The author takes no responsibility for the content those services return, or for how the add-on is used.[/COLOR]</description>
		<platform>all</platform>
		<license>GNU GENERAL PUBLIC LICENSE. Version 3, 29 June 2007</license>
		<disclaimer lang="en">[COLOR ffc75453]This add-on hosts no content and includes no links of its own. It only queries third-party services that you set up with your own accounts. You are solely responsible for the sources you choose to enable and for complying with the copyright laws of your country. Use at your own risk.[/COLOR]</disclaimer>
	  <assets>
		<icon>icon.png</icon>
		<fanart>fanart.jpg</fanart>
		<screenshot>resources/screenshot1.jpg</screenshot>
        <screenshot>resources/screenshot2.jpg</screenshot>
        <screenshot>resources/screenshot3.jpg</screenshot>
      </assets>
    </extension>
</addon>



