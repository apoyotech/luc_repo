<addon id="service.luc_kodi.tmdbextendedinfo"
       name="service.luc_kodi.tmdbextendedinfo"
       version="0.0.2"
       provider-name="angelitto,[COLOR fffdb515]apoyotech[/COLOR]">
    <requires>
        <import addon="xbmc.python" version="3.0.1" />
        <import addon="script.module.requests" />
    </requires>

    <extension point="xbmc.service" library="service.py" />

    <extension point="xbmc.python.script" library="script_entry.py" />

    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
            <item library="context_extended.py">
                <label>[B][COLOR FFFDB515]Extras[/COLOR][/B]</label>
                <visible>
                    System.HasAddon(plugin.video.luc_kodi) +
                    String.IsEqual(Window(10000).Property(LucKodi.TMDbExtendedContext),true) +
                    !String.IsEmpty(ListItem.Title) +
                    [String.IsEqual(ListItem.DBTYPE,movie) | String.IsEqual(ListItem.DBTYPE,tvshow) | String.IsEqual(ListItem.DBTYPE,season) | String.IsEqual(ListItem.DBTYPE,episode) |                     !String.IsEmpty(ListItem.Property(mediatype))]
                </visible>
            </item>
        </menu>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="en">[COLOR ffc75453]TMDb Extended Info context menu &amp; dialogs for plugin.video.luc_kodi[/COLOR]</summary>
        <description lang="en">Adds a context-menu entry that opens an Extended Info dialog (cast, videos, images, seasons/episodes).</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>



